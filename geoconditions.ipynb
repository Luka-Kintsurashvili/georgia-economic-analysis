import pandas as pd
import matplotlib.pyplot as plt

earnings_data = pd.read_csv('01_Earnings_annual.csv', skiprows=2)
weights_data = pd.read_csv('Consumer-basket-weights.csv', skiprows=3)

years = ['2012', '2013', '2014', '2015', '2016', '2017', '2018', '2019', '2020', '2021', '2022', '2023', '2024']

total_salary = earnings_data.iloc[0][years].astype(float)

food_row = weights_data.iloc[1][years]

food_clean = []
for val in food_row:
    
    clean_val = str(val).replace('%', '')
    food_clean.append(float(clean_val))

fig, ax1 = plt.subplots(figsize=(10, 6))

ax1.plot(years, total_salary, color='green', marker='o', label='Monthly Salary (GEL)')
ax1.set_xlabel('Year')
ax1.set_ylabel('Earnings in GEL', color='green')

ax2 = ax1.twinx()
ax2.plot(years, food_clean, color='red', marker='x', linestyle='--', label='Food Weight %')
ax2.set_ylabel('Food % of Total Budget', color='red')

plt.title('My Analysis: Georgian Income vs. Food Costs (2012-2024)')
plt.grid(True, alpha=0.3)
plt.show()

fig.savefig('my_georgia_analysis.png')
print("Done! Chart saved.")
